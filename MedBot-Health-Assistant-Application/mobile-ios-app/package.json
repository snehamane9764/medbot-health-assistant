{
  "name": "medbot-health-assistant",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir dist && node scripts/prepare-web-dist.js",
    "offline:web": "npm run build:web && node scripts/serve-offline.js dist 4173",
    "offline:web:phone": "npm run build:web && node scripts/serve-offline.js dist 4173 0.0.0.0",
    "build:ios": "eas build --platform ios --profile preview",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-dom": "19.1.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2"
  }
}
